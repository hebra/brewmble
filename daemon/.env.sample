# Sample environment configuration for the Brewmble daemon.
# Copy this file to .env and adjust the values as needed, or set the variables
# directly in the environment that starts brewmbled.

# -----------------------------------------------------------------------------
# Network / mDNS identity
# -----------------------------------------------------------------------------

# Port to listen on for the HTTP API.
# If not specified, the daemon searches for a free port starting from 4712.
# BREWMBLE_DAEMON_PORT=4712

# Hostname to advertise via mDNS service discovery.
# Defaults to the system hostname (first segment before any dot).
# BREWMBLE_DAEMON_HOSTNAME=brewmbled

# Explicit IP address to advertise via mDNS.
# Defaults to auto-detected local addresses if not set.
# BREWMBLE_DAEMON_IP=192.168.1.42

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# API key used to authenticate clients via the X-API-Key header.
# If omitted, the daemon generates a random UUID v4 and logs it on startup.
# BREWMBLE_DAEMON_API_KEY=change-me-to-a-long-secret-key

# -----------------------------------------------------------------------------
# Upgrade behaviour
# -----------------------------------------------------------------------------

# Allow the daemon to reboot the host when requested through the API.
# Set to "true" to enable; defaults to false.
# BREWMBLE_DAEMON_ALLOW_REBOOT=false

# Automatically clean downloaded packages after a successful upgrade.
# Set to "true" to enable; defaults to false.
# BREWMBLE_DAEMON_AUTO_CLEAN=false

# Automatically remove unused packages after a successful upgrade.
# Set to "true" to enable; defaults to false.
# BREWMBLE_DAEMON_AUTO_REMOVE=false

# -----------------------------------------------------------------------------
# Update cache TTLs
# -----------------------------------------------------------------------------

# Cache time-to-live, in minutes, for apt-get update results.
# The daemon skips re-running apt-get update while cached results are fresh.
# Defaults to 360 minutes (6 hours).
# BREWMBLE_APT_UPDATE_INTERVAL=360

# Cache time-to-live, in minutes, for brew update results.
# The daemon skips re-running brew update while cached results are fresh.
# Defaults to 360 minutes (6 hours).
# BREWMBLE_BREW_UPDATE_INTERVAL=360
